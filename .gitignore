# =============================================================================
# .gitignore — MODEL_master (repo cosmos-design)
# Racine du dépôt. Le site est servi par GitHub Pages depuis docs/.
# =============================================================================

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- OneDrive ---
~$*

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.env
.env.local

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log

# --- Node (au cas où) ---
node_modules/

# --- Artefacts de build (lourds, non versionnés) ---
docs/**/standalone_*.html
standalone_*.html

